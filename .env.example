# Contact form → Google Sheets (Apps Script web app).
# Copy this file to `.env.local` and fill in the values, then rebuild.
# See ../CONTACT-SHEETS-SETUP.md for how to get these.
#
# NOTE: NEXT_PUBLIC_* values are inlined into the client bundle at build time,
# so they are public. The token is only a low-effort spam guard, not a secret.

# The Apps Script web-app deployment URL (ends in /exec)
NEXT_PUBLIC_SHEETS_ENDPOINT=

# A shared string you also paste into the Apps Script (TOKEN constant)
NEXT_PUBLIC_SHEETS_TOKEN=
